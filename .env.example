# Copy to .env.local for local development. Do not commit .env.local.
# Values are pulled from Supabase → Project Settings → API.

VITE_SUPABASE_URL=https://REPLACE_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=REPLACE_ANON_PUBLIC_KEY

# Optional: override the EA edge function URL (defaults to {SUPABASE_URL}/functions/v1/ea-chat)
# VITE_EA_FUNCTION_URL=
